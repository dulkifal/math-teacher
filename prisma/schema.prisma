generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
model UserScore {
  id               Int      @id @default(autoincrement())
  userId           String   @unique
  score            Int      @default(0)
  currentStreak    Int      @default(0)
  highestStreak    Int      @default(0)
  lastActivityAt   DateTime?
}

model UserProgress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
}

model QuizAttempt {
  id        String   @id @default(cuid())
  userId    String
  topic     String
  score     Int
  total     Int
  createdAt DateTime @default(now())
}

model ConceptMastery {
  id          String   @id @default(cuid())
  userId      String
  conceptId   String
  proficiency Float    @default(0.0) // 0.0 to 1.0 (or 0 to 100)
  updatedAt   DateTime @updatedAt

  @@unique([userId, conceptId])
}

model AnswerHistory {
  id          String   @id @default(cuid())
  userId      String
  conceptId   String
  questionId  String
  isCorrect   Boolean
  timeSpentMs Int?
  createdAt   DateTime @default(now())
}
